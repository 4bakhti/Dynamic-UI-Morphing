# Copy this file to .env.local and fill in your key.
# cp .env.local.example .env.local   (or copy/paste on Windows)

# Your OpenAI API key (required when DEMO_MODE is false)
OPENAI_API_KEY=sk-...

# Demo safety net.
#   true  -> the API route streams the exact pre-compiled JSON (no LLM call).
#            Guarantees the on-stage output matches Abdurahmon's live app.
#   false -> the Developing Agent makes a real live OpenAI call.
DEMO_MODE=true

# --- Optional: public-deployment hardening -------------------------------
# Shared access code for the live LLM path. When set, every request must send
# a matching code (the portal UI has an "Access code" field) or it gets a 401.
# Leave unset to keep the endpoints open, as the local demo expects.
# PORTAL_ACCESS_CODE=

# Optional shared rate-limit store. When both are set, the per-IP + global
# budget is enforced in Upstash Redis so it holds across serverless instances;
# unset, the limiter falls back to the in-memory per-instance budget.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
