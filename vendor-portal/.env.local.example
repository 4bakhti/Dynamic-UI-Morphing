# Copy this file to .env.local and fill in your key.
# cp .env.local.example .env.local   (or copy/paste on Windows)

# Your OpenAI API key (required when DEMO_MODE is false)
OPENAI_API_KEY=sk-...

# Demo safety net.
#   true  -> the API route streams the exact pre-compiled JSON (no LLM call).
#            Guarantees the on-stage output matches Abdurahmon's live app.
#   false -> the Developing Agent makes a real live OpenAI call.
DEMO_MODE=true
